# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/

# Datasets — 大体积媒体文件不进 git,保留 README / manifest 作为索引
# (输入位置可经 INFRACOMP_DATASETS_DIR 配置、不固定,故按扩展名忽略而非目录名)
datasets/FLIR_ADAS_1_3/
datasets/**/*.mp4
datasets/**/*.avi
datasets/**/*.mov
datasets/**/*.mkv
datasets/**/*.m4v
datasets/**/*.webm
datasets/**/*.y4m
datasets/**/*.png
datasets/**/*.jpg
datasets/**/*.jpeg
datasets/**/*.tif
datasets/**/*.tiff
datasets/**/*.bmp
datasets/**/*.zip
datasets/contour/*/_raw_frames/
# datasets/README.md、datasets/manifest.json、datasets/contour/*/manifest.json 等小文件默认被追踪

# Environment
.env
.env.local
.qoder/

# Web frontend
web/node_modules/
web/dist/
web/.vite/

# Backend runtime
backend.log
frontend.log
.playwright-mcp/

# SQLite + caches
data/*.db
papers/cache/

# Benchmark runtime outputs (regenerate by running baselines; ignore ALL of them)
results/video/*.json
results/video/*.csv
results/video/*.md
results/video/*.html
results/video/bitstreams/
results/video/recon/
results/video/_raw_frames/
results/video/charts/

# Debug screenshots
papers-with-previews.png

# OS
.DS_Store
Thumbs.db

# Training run outputs (checkpoints/logs/metrics; reproducible, not committed)
results/training/checkpoints/*.pth
results/training/logs/*.log
results/training/metrics.json
