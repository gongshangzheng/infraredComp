# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/

# Datasets — 整个 datasets/ 不进 git(大数据集物理在 D:/data,junction 进 datasets/;
# 索引/manifest 由代码 + D:/data 管理,不再 tracked)
datasets/

# Temp/test artifacts (not committed)
_*.yuv
_*.png
_*.bin
_test.*

# DCVC checkpoints (vendored weights, large)
pretrained/

# Preview/visualizations (generated)
results/video/
results/training/viz/
results/hed_preview.png

# DCVC source (cloned nested repo, not part of this repo)
third_party/DCVC/

# Environment
.env
.env.local
.qoder/

# Web frontend
web/node_modules/
web/dist/
web/.vite/

# Backend runtime
backend.log
frontend.log
.playwright-mcp/

# SQLite + caches
data/*.db
papers/cache/

# Benchmark runtime outputs (regenerate by running baselines; ignore ALL of them)
results/video/*.json
results/video/*.csv
results/video/*.md
results/video/*.html
results/video/bitstreams/
results/video/recon/
results/video/_raw_frames/
results/video/charts/

# Debug screenshots
papers-with-previews.png

# OS
.DS_Store
Thumbs.db

# Training run outputs (checkpoints/logs/metrics; reproducible, not committed)
results/training/checkpoints/*.pth
results/training/logs/*.log
results/training/metrics.json

# Vendored HED model binary (56 MB; deploy.prototxt is tracked, the caffemodel is not)
third_party/hed/*.caffemodel
logs/
results/video/contour_mp4/
results/video/row_demo/
results/video/source/
third_party/pidinet/*.pth
third_party/yoloe26/*.pt

# ultralytics mobileclip2 text-model cache (auto-downloaded, ~253MB, never commit)
mobileclip2_*.ts
mobileclip2_*.pt

# NEVC checkpoints (HF ByteDance/NEVC1.0, gitignore weights only; src/ tracked)
third_party/nevc/models/*.pth.tar
third_party/nevc/models/*.pth
third_party/lsmc/*.exe
